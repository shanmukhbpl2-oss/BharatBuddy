# ============================================
# BharatBuddy — Environment Variables
# Copy this file to .env and fill in your keys
# ============================================

# 🤖 Anthropic Claude API Key (required)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 🎙️ Sarvam AI API Key (required for voice features)
# Get from: https://app.sarvam.ai/
SARVAM_API_KEY=your_sarvam_api_key_here

# 📱 AiSensy WhatsApp API Key (optional — for WhatsApp bot)
# Get from: https://aisensy.com/
AISENSY_API_KEY=your_aisensy_api_key_here

# 🔒 WhatsApp Webhook Verify Token (optional — set any secret string)
WEBHOOK_VERIFY_TOKEN=bharatbuddy_verify

# 🌐 Server Port (default: 3001)
PORT=3001
