# ============================================
# BharatBuddy — Environment Variables
# Copy this file to .env and fill in your keys
# ============================================

# 🤖 Anthropic Claude API Key (REQUIRED - for AI chat)
# Get from: https://console.anthropic.com/
# Note: Add credits to your account after getting the key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 🗄️ MongoDB Connection URI (REQUIRED - for data storage)
# Get from: https://mongodb.com/cloud/atlas (free tier available)
# Format: mongodb+srv://username:password@cluster.mongodb.net/bharatbuddy
MONGODB_URI=your_mongodb_connection_string_here

# 🎙️ Sarvam AI API Key (Optional - for Hindi voice TTS/STT features)
# Get from: https://app.sarvam.ai/
# Note: Required only if using voice features
SARVAM_API_KEY=your_sarvam_api_key_here

# 📱 AiSensy WhatsApp API Key (Optional - for WhatsApp bot integration)
# Get from: https://aisensy.com/
# Note: Required only if using WhatsApp integration
AISENSY_API_KEY=your_aisensy_api_key_here

# 🔒 WhatsApp Webhook Verify Token (Optional - set any secret string)
# Used for webhook verification with WhatsApp
WEBHOOK_VERIFY_TOKEN=bharatbuddy_verify_token_12345

# 🌐 Server Port (Optional - defaults to 3001 if not set)
PORT=3001

# ============================================
# QUICK SETUP GUIDE
# ============================================
#
# 1. COPY THIS FILE:
#    Copy .env.example to .env in the same directory
#
# 2. GET ANTHROPIC API KEY (Required):
#    - Visit https://console.anthropic.com/
#    - Sign up / Login
#    - Generate API key
#    - Add credits ($5-10 recommended)
#    - Paste key above
#
# 3. SETUP MONGODB (Required):
#    - Go to https://mongodb.com/cloud/atlas
#    - Create free M0 cluster
#    - Create database user (username + password)
#    - Whitelist IP (0.0.0.0/0 for testing)
#    - Get connection string
#    - Replace <password> with your actual password
#
# 4. OPTIONAL - Voice Features:
#    - Visit https://app.sarvam.ai/
#    - Sign up for API access
#    - Get API key for Hindi TTS/STT
#
# 5. OPTIONAL - WhatsApp Integration:
#    - Visit https://aisensy.com/
#    - Create account
#    - Get API credentials
#    - Setup webhook URL
#
# 6. SAVE .env FILE AND RESTART SERVER
#    npm start
#
# ============================================
